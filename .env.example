# Bu dosyayı .env olarak kopyala ve doldur
# Railway'de bu değerleri Environment Variables bölümüne gireceksin

# Lemon Squeezy
LS_WEBHOOK_SECRET=buraya_webhook_secret_gelecek
LS_VARIANT_15S=buraya_15sn_variant_id_gelecek
LS_VARIANT_30S=buraya_30sn_variant_id_gelecek
LS_CHECKOUT_BASE=https://MAGAZAN.lemonsqueezy.com/checkout/buy

# Evolink (Seedance 2.0)
EVOLINK_API_KEY=buraya_evolink_api_key_gelecek
EVOLINK_BASE_URL=https://api.evolink.ai

# Epidemic Sound
EPIDEMIC_SOUND_API_KEY=buraya_epidemic_sound_key_gelecek

# AWS S3
AWS_ACCESS_KEY_ID=buraya_aws_key_gelecek
AWS_SECRET_ACCESS_KEY=buraya_aws_secret_gelecek
AWS_REGION=eu-central-1
S3_BUCKET=esnafajan-media

# Redis - Railway otomatik dolduruyor, elle yazma
REDIS_URL=redis://localhost:6379

# Sunucu portu - Railway otomatik dolduruyor
PORT=3000
